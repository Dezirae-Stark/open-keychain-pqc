    <color name="key_flag_red">#f44336</color>
    <color name="key_flag_orange">#ff9800</color>
    <color name="key_flag_green">#7bad45</color>

    <!--
        Standard Android colors:
        http://www.google.com/design/spec/style/color.html#color-color-palette
        light = normal color
        dark = 900

        exception: green
    -->
    <color name="android_red_light">#f44336</color>
    <color name="android_red_dark">#b71c1c</color>
    <color name="android_orange_light">#ff9800</color>
    <color name="android_green_light">#7bad45</color>
    <color name="android_green_dark">#6c983d</color>

    <!-- text protection scrim colors -->

    <!-- linked ID view -->
    <color name="card_view_button">#7bad45</color>

    <color name="pressed_gray">#0c000000</color>
    <color name="selected_gray">#2c000000</color>

    <!--
        OpenKeychain PQC brand palette. Deliberately distinct from stock OpenKeychain's green,
        so this fork reads as its own thing at a glance in the app switcher, launcher, and every
        toolbar, not just a differently-labeled copy. Midnight violet base (a cyberpunk
        base color, not the near-black-plus-one-hot-accent look every AI-generated dark theme
        reaches for) with electric cyan as the primary accent (better contrast and no red/green
        colorblindness collision, versus a red accent) and magenta reserved for exactly one
        signature highlight (the FAB) rather than spread across the whole UI. Red stays exactly
        where it already was semantically: key-health warnings, the standalone-PQC
        non-interop dialog, not repurposed as a general accent, so it keeps meaning "warning."
    -->
    <color name="pqc_violet_deepest">#150E29</color>
    <color name="pqc_violet_primary">#2D1B69</color>
    <color name="pqc_violet_primary_dark">#1A0F42</color>
    <color name="pqc_violet_surface">#221452</color>
    <color name="pqc_violet_surface_light">#F1EEFB</color>
    <color name="pqc_cyan_accent">#00E5FF</color>
    <color name="pqc_cyan_accent_pressed">#00B8CC</color>
    <!-- Deeper variant for the light theme: full-neon cyan is two light colors touching
         (near-white cyan on a white/light surface) and reads as washed out rather than vivid,
         so this keeps the same hue family with contrast that actually works on a light background. -->
    <color name="pqc_cyan_accent_on_light">#0097A7</color>
    <color name="pqc_cyan_accent_on_light_pressed">#00747F</color>
    <color name="pqc_magenta_signature">#FF2ED1</color>
    <color name="pqc_magenta_signature_pressed">#CC1FA8</color>

</resources>
